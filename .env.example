# ── open-balena-extension configuration ─────────────────────────────────────
# Copy to .env and fill in. NEVER commit the real .env.

# Internal openBalena TLD — what the core stack is deployed under (DNS_TLD).
# Devices and services get *.${DNS_TLD} endpoints from the API.
DNS_TLD=example.local

# Public hostname the instance is reached at through your reverse proxy / public DNS.
# A wildcard *.${PUBLIC_TLD} must resolve to the host (covers api., registry2., vpn.,
# cloudlink., delta., builder., etc.). Remote device images are rewritten to this.
# If you run a single public TLD with no internal split, set PUBLIC_TLD == DNS_TLD.
PUBLIC_TLD=ob.example.com

# Public dashboard hostname (admin UI), if used.
DASHBOARD_HOST=balena.example.com

# Install root on the host.
INSTALL_ROOT=/opt/openbalena
SERVICE_USER=balena

# ── Secrets (generate; do not reuse these examples) ─────────────────────────
# Builder token — MUST equal the core API's TOKEN_AUTH_BUILDER_TOKEN.
# Read it from the running API: docker exec open-balena-api-1 sh -c \
#   'cat /proc/$(pgrep -f node|head -1)/environ | tr "\0" "\n" | grep TOKEN_AUTH_BUILDER_TOKEN'
TOKEN_AUTH_BUILDER_TOKEN=

# Admin dashboard secrets (community open-balena-ui stack)
OPEN_BALENA_JWT_SECRET=
OPEN_BALENA_S3_ACCESS_KEY=
OPEN_BALENA_S3_SECRET_KEY=
PGRST_JWT_SECRET=

# balena CLI version baked into the patched builder image (avoid expired releases).
BALENA_CLI_VERSION=v22.1.2
